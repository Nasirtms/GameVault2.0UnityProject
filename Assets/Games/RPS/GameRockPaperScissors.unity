  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<color=#e49027>\u2022</color>  When the player's hand wins, 1 prize is
    won\n    as <color=yellow> indicated</color> by the prize wheel on the game\n
    screen, and the game ends.\n<color=#e49027>\u2022</color>  The prize wheel level
    starts at 1 in the\n    first game in increments 1 level higher in\n    each
    game following a tie until the\n    maximum prize wheel level of 5 is reached.\n<color=#e49027>\u2022</color>
    prizes available are as shown below."
